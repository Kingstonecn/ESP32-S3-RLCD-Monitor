#pragma once

// Copy to secrets.h (gitignored) and fill in.
#define RLCD_WIFI_SSID     "your-ssid"
#define RLCD_WIFI_PASSWORD "your-pass"

// Bridge endpoint. Append ?mock=1 during firmware UI work.
// LAN PC:        "http://192.168.1.42:7777/api/usage"
// ZT/Tailscale:  "http://10.x.x.x:7777/api/usage"  (VPS's overlay IP)
#define RLCD_BRIDGE_URL    "http://10.x.x.x:7777/api/usage"

// If the bridge sets RLCD_AUTH_TOKEN, set the same string here. Sent as
// X-RLCD-Token header. Leave empty if the bridge has no token configured.
#define RLCD_BRIDGE_TOKEN  ""

// Poll interval in seconds. 60 matches the bridge default cache TTL.
#define RLCD_POLL_SEC      60
