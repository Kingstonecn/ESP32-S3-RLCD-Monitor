#pragma once

// Copy this to secrets.h (gitignored) and fill in.

#define RLCD_WIFI_SSID     "your-ssid"
#define RLCD_WIFI_PASSWORD "your-pass"

// Bridge endpoint. Append ?mock=1 during UI bring-up.
//   LAN PC:        "http://192.168.1.42:7777/api/usage"
//   ZT/Tailscale:  "http://10.147.20.5:7777/api/usage"   <- overlay-network IP of bridge host
#define RLCD_BRIDGE_URL    "http://192.168.1.42:7777/api/usage"

// If the bridge sets RLCD_AUTH_TOKEN, set the same string here.
// Sent as `X-RLCD-Token` header. Empty = no auth.
#define RLCD_BRIDGE_TOKEN  ""

// HTTP poll interval; matches bridge cache TTL.
// DeepSeek usage changes slowly, polling every 5 min is enough and keeps the
// radio idle (light sleep) the rest of the time.
#define RLCD_POLL_SEC      300
